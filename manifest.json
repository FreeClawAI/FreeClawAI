{
  "manifest_version": 3,
  "name": "FreeClawAI",
  "version": "1.0.0",
  "description": "Code AI, Free Forever. Grab code from AI chats, save locally.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": ["http://127.0.0.1:8080/*", "http://localhost:8080/*"],
  "content_scripts": [{
    "matches": [
      "https://chat.deepseek.com/*",
      "https://chat.openai.com/*",
      "https://chatgpt.com/*",
      "https://claude.ai/*",
      "https://gemini.google.com/*"
    ],
    "js": [
      "lib/diff.js",
      "lib/beautify.js",
      "lib/beautify-css.js",
      "lib/beautify-html.js",
      "js/core/utils.js",
      "js/core/md5.js",
      "js/core/db.js",
      "js/core/config.js",
      "js/core/i18n.js",
      "js/core/messages.js",
      "js/services/api.js",
      "js/sites/adapters.js",
      "js/services/extractor.js",
      "js/services/file-service.js",
      "js/services/sender.js",
      "js/services/formatter.js",
      "js/services/quick-save.js",
      "js/services/send-btn.js",
      "js/ui/dialog.js",
      "js/ui/toast.js",
      "js/ui/panel.js",
      "js/ui/preview.js",
      "js/ui/editor.js",
      "js/ui/prompts-bar.js",
      "js/ui/templates-bar.js",
      "js/ui/file-tree.js",
      "js/ui/diff-dialog.js",
      "js/ui/save-dialog.js",
      "js/ui/send-dialog.js",
      "js/ui/settings-dialog.js",
      "js/ui/context-menu.js",
      "js/ui/dir-picker.js",
      "js/ui/quick-msg.js",
      "js/ui/ai-sites-dialog.js",
      "js/ui/code-folder.js",
      "js/input/keyboard.js",
      "js/input/dnd.js",
      "content.js"
    ],
    "css": ["panel.css"]
  }],
  "web_accessible_resources": [{
    "resources": ["panel.css", "js/*", "lib/*", "server.js"],
    "matches": ["<all_urls>"]
  }],
  "action": {
    "default_title": "FreeClaw - Code AI, Free Forever",
    "default_popup": "popup.html"
  }
}